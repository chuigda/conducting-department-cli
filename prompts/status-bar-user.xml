<input>
    <memory type="coarse" comment="Summary of previous events">
        {$COARSE_MEMORY}
    </memory>
    <memory type="precise" comment="Summary of recent events">
        {$PRECISE_MEMORY}
    </memory>

    <simulator comment="Output before user's instruction action">
        {$SIMULATOR_OUTPUT_BEFORE_USER_INSTRUCTION}
